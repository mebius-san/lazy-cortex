#!/usr/bin/env python3

"""CLI entry shim for lazy-specs.

Subcommands dispatched here:

- `open-request <file>` — mechanical opt-in handler for naked request
  files. Invoked by the `spec.request-open` md-scan routine; writes
  the minimum frontmatter + banner and commits under the
  `spec.request-open` bot identity. No LLM dispatch — the LLM apply
  transition (`spec.request-apply` agent) fires later when the
  request reaches the post-finalize stage.
"""
from __future__ import annotations
# waiver: lazy sibling imports below -- flat bin/ dir resolved via sys.path at runtime, not statically importable
# pylint: disable=import-error

import sys
from pathlib import Path

from typing import TYPE_CHECKING
if TYPE_CHECKING:
  pass


_BIN = Path(__file__).resolve().parent
if str(_BIN) not in sys.path:
  sys.path.insert(0, str(_BIN))

# waiver: subcommand name strings -- dispatch keys for the CLI router, one per registered subcommand
_SUB_OPEN_REQUEST = "open-request"
_SUB_APPLY_REQUEST = "apply-request"
_SUB_RESOLVE_PRODUCT = "resolve-product"
_SUB_RESOLVE_LANGUAGE = "resolve-language"
_SUB_FLIP_GATE = "flip-gate"
_SUB_GATE_TICK = "gate-tick"
_SUB_SCAFFOLD_ASSET = "scaffold-asset"
_SUB_RENDER_CONTAINER_STATS = "render-container-stats"
# waiver: usage string -- help text printed to stderr; not a domain constant
_USAGE = (
    "usage: lazycortex-specs <subcommand> [args...]\n"
    "subcommands:\n"
    "  open-request <file>            mechanical opt-in for naked request file\n"
    "  resolve-product <by-key|by-path> ...   resolve a product from settings\n"
    "  resolve-language <relpath>     resolve a doc's effective language\n"
    "  flip-gate <asset_dir> <gate> [--off] [--auto] [--reason TEXT]   move one gate\n"
    "  gate-tick <asset_note> [--today YYYY-MM-DD]   advance one asset's gates\n"
    "  scaffold-asset <product> <category> <slug>  deterministic scaffold of a new asset folder\n"
    "  apply-request <file>           deterministic post-finalize apply transition for a request file\n"
    "  render-container-stats <note>  recompute a container note's stats region\n"
)


def main(argv: list[str]) -> int:
  """
  Dispatch a lazycortex-specs subcommand from the CLI argument list.

  Args:
    argv: Argument list (typically `sys.argv[1:]`).

  Returns:
    Exit code: `0` on success, `2` on bad arguments or unknown subcommand.
  """
  if not argv or argv[0] in ("-h", "--help"):
    sys.stderr.write(_USAGE)
    return 0 if argv else 2
  sub, *rest = argv
  if sub == _SUB_OPEN_REQUEST:
    # waiver: lazy sibling import -- flat bin/ dir resolved via sys.path at runtime, not statically importable
    import open_request  # type: ignore  # waiver: bare-name sibling, not resolvable by mypy
    return open_request.main(rest)
  if sub == _SUB_APPLY_REQUEST:
    # waiver: lazy sibling import -- flat bin/ dir resolved via sys.path at runtime, not statically importable
    import apply_request  # type: ignore  # waiver: bare-name sibling, not resolvable by mypy
    return apply_request.main(rest)
  if sub == _SUB_RESOLVE_PRODUCT:
    # waiver: lazy sibling import -- flat bin/ dir resolved via sys.path at runtime, not statically importable
    import resolve_product  # type: ignore  # waiver: bare-name sibling, not resolvable by mypy
    return resolve_product.main(rest)
  if sub == _SUB_RESOLVE_LANGUAGE:
    # waiver: lazy sibling import -- flat bin/ dir resolved via sys.path at runtime, not statically importable
    import resolve_language  # type: ignore  # waiver: bare-name sibling, not resolvable by mypy
    return resolve_language.main(rest)
  if sub == _SUB_FLIP_GATE:
    # waiver: lazy sibling import -- flat bin/ dir resolved via sys.path at runtime, not statically importable
    import flip_gate  # type: ignore  # waiver: bare-name sibling, not resolvable by mypy
    return flip_gate.main(rest)
  if sub == _SUB_GATE_TICK:
    # waiver: lazy sibling import -- flat bin/ dir resolved via sys.path at runtime, not statically importable
    import gate_tick  # type: ignore  # waiver: bare-name sibling, not resolvable by mypy
    return gate_tick.main(rest)
  if sub == _SUB_SCAFFOLD_ASSET:
    # waiver: lazy sibling import -- flat bin/ dir resolved via sys.path at runtime, not statically importable
    import scaffold_asset  # type: ignore  # waiver: bare-name sibling, not resolvable by mypy
    return scaffold_asset.main(rest)
  if sub == _SUB_RENDER_CONTAINER_STATS:
    # waiver: lazy sibling import -- flat bin/ dir resolved via sys.path at runtime, not statically importable
    import summary_render  # type: ignore  # waiver: bare-name sibling, not resolvable by mypy
    return summary_render.main(rest)
  sys.stderr.write(f"unknown subcommand: {sub}\n")
  return 2


if __name__ == "__main__":
  sys.exit(main(sys.argv[1:]))
