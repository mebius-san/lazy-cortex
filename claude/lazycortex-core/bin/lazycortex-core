#!/usr/bin/env python3
"""lazycortex-core CLI dispatcher."""
import os, sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).parent))

USAGE = ("usage: lazycortex-core <subcommand> [args...]\n"
         "Subcommands: expert-pump-once, doctor-tick, runtime, resume, memory-reflect-all, dispatch-job, collect-job, consume-job, lookup-expert, scaffold, error-record, error-list, settings-get, settings-set")


def _cmd_consume_job(argv: list[str]) -> int:
    """Inter-plugin job-consume entrypoint. Reads ``{expert, job_id}``
    JSON from stdin, marks the job as consumed via
    ``expert_runtime.consume_job``, prints ``{"status": "ok"}`` on
    success.

    Idempotent: re-consuming an already-consumed job is a no-op.
    Missing job dir is also a no-op (already cleaned up).

    This is the contract sibling plugins use to retire a job after
    they have applied or explicitly discarded its response.
    """
    import json
    from pathlib import Path as _Path
    from expert_runtime import consume_job as _consume
    repo = _Path(os.environ.get("LAZY_REPO_ROOT", os.getcwd()))
    try:
        req = json.load(sys.stdin)
    except json.JSONDecodeError as e:
        print(json.dumps({"error": f"request parse: {e}"})); return 1
    expert = req.get("expert")
    job_id = req.get("job_id")
    if not expert or not job_id:
        print(json.dumps({"error": "request missing 'expert' or 'job_id'"})); return 1
    dispatched_from = req.get("dispatched_from")
    df_kw = {"dispatched_from": _Path(dispatched_from)} if dispatched_from else {}
    try:
        _consume(repo, expert, job_id, **df_kw)
    except Exception as e:
        print(json.dumps({"error": f"consume failed: {e}"})); return 1
    print(json.dumps({"status": "ok"}))
    return 0


def _cmd_collect_job(argv: list[str]) -> int:
    """Inter-plugin job-collection entrypoint. Reads ``{expert, job_id}``
    JSON from stdin, queries ``expert_runtime.collect_job``, prints the
    status dict to stdout.

    Output JSON:
      ``{"status": "pending|done|failed|missing", "response": {...}}``
      (``response`` is present only when ``status`` is ``done`` or ``failed``.)

    This is the read-side companion to ``dispatch-job`` — the contract
    sibling plugins use to inspect a job they earlier queued. Same
    rationale: no filesystem-walk imports across plugin boundaries.
    """
    import json
    from pathlib import Path as _Path
    from expert_runtime import collect_job as _collect
    repo = _Path(os.environ.get("LAZY_REPO_ROOT", os.getcwd()))
    try:
        req = json.load(sys.stdin)
    except json.JSONDecodeError as e:
        print(json.dumps({"error": f"request parse: {e}"})); return 1
    expert = req.get("expert")
    job_id = req.get("job_id")
    if not expert or not job_id:
        print(json.dumps({"error": "request missing 'expert' or 'job_id'"})); return 1
    try:
        out = _collect(repo, expert, job_id)
    except Exception as e:
        print(json.dumps({"error": f"collect failed: {e}"})); return 1
    print(json.dumps(out))
    return 0


def _cmd_dispatch_job(argv: list[str]) -> int:
    """Inter-plugin job-creation entrypoint. Reads a JSON job-bundle
    from stdin, atomically creates the job dir via
    ``expert_runtime.dispatch_job``, prints the result JSON to stdout.

    Input bundle (stdin, JSON):
      ``{ "expert": "<name>", "payload": {...}, "protocols": [...],
          "source": {filename: text}, "context": {filename: text},
          "result": [filename, ...], "job_id": "...", "dedup_key": "..." }``

    Output (stdout, JSON):
      ``{"job_id": "...", "queue_path": "..."}`` on fresh dispatch,
      ``{"job_id": "...", "status": "already-queued"}`` on dedup hit.

    Exit codes: 0 on success, 1 on bundle parse / dispatch error
    (error JSON on stdout).

    This is the contract sibling plugins MUST use to queue jobs —
    never reach into ``expert_runtime`` directly via filesystem-walk
    imports.
    """
    import json
    from pathlib import Path as _Path
    from expert_runtime import dispatch_job as _dispatch
    repo = _Path(os.environ.get("LAZY_REPO_ROOT", os.getcwd()))
    try:
        bundle = json.load(sys.stdin)
    except json.JSONDecodeError as e:
        print(json.dumps({"error": f"bundle parse: {e}"})); return 1
    # Cross-repo `@<repo>` parsing: if bundle.expert carries "@<key>", parse and
    # resolve target, swap repo for dispatch, and synthesize dispatched_from
    # so the tracker lands in the caller's repo. Bare names pass through.
    raw_expert = bundle.get("expert") or ""
    target_repo = repo
    expert_for_dispatch = raw_expert
    df_kw: dict = {}
    if "@" in raw_expert:
        try:
            from expert_name import parse as _parse_expert_name
            from repo_resolver import resolve as _resolve_target_repo
            expert_for_dispatch, repo_key = _parse_expert_name(raw_expert)
            target_repo = _resolve_target_repo(repo, repo_key)
        except Exception as e:
            print(json.dumps({"error": f"cross-repo resolve failed: {e}"})); return 1
        if target_repo != repo.resolve():
            df_kw = {"dispatched_from": repo}
    # Explicit bundle.dispatched_from overrides (rarely used; CLI callers
    # that already know the dispatching repo can pass it).
    if "dispatched_from" in bundle and bundle["dispatched_from"]:
        df_kw = {"dispatched_from": _Path(bundle["dispatched_from"])}
    try:
        out = _dispatch(
            target_repo,
            expert_for_dispatch,
            bundle.get("payload") or {},
            protocols=bundle.get("protocols"),
            source=bundle.get("source"),
            context=bundle.get("context"),
            result=bundle.get("result"),
            job_id=bundle.get("job_id"),
            dedup_key=bundle.get("dedup_key"),
            **df_kw,
        )
    except KeyError as e:
        print(json.dumps({"error": f"missing required bundle field: {e}"})); return 1
    except Exception as e:
        print(json.dumps({"error": f"dispatch failed: {e}"})); return 1
    print(json.dumps(out))
    return 0


def _cmd_lookup_expert(argv: list[str]) -> int:
    """Read ``{"name": "..."}`` from stdin; print
    ``{"found": true, "entry": {...}}`` or ``{"found": false}`` to stdout.
    Exit 0 in both cases; non-zero only on settings I/O / parse error.
    """
    import json
    from pathlib import Path as _Path
    repo = os.environ.get("LAZY_REPO_ROOT")
    if not repo:
        print("LAZY_REPO_ROOT not set", file=sys.stderr)
        return 2
    try:
        body = json.loads(sys.stdin.read() or "{}")
    except json.JSONDecodeError as e:
        print(f"stdin not JSON: {e}", file=sys.stderr)
        return 2
    name = body.get("name")
    if not name:
        print('stdin missing "name"', file=sys.stderr)
        return 2
    from expert_runtime import _resolve_expert_entry
    entry = _resolve_expert_entry(_Path(repo), name)
    if entry:
        print(json.dumps({"found": True, "entry": entry}))
    else:
        print(json.dumps({"found": False}))
    return 0


def _cmd_memory_reflect_all(argv: list[str]) -> int:
    """Dispatch a kind=reflect job for every persona-marked expert.
    Flags: --dry-run (list targets but don't dispatch), --days N (log window)."""
    import argparse, json, time
    parser = argparse.ArgumentParser(prog="lazycortex-core memory-reflect-all")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--days", type=int, default=30)
    args = parser.parse_args(argv)

    from lazy_settings import load_section
    from expert_runtime import dispatch_job

    repo = Path(os.environ.get("LAZY_REPO_ROOT", os.getcwd()))
    experts = load_section(repo / ".claude/lazy.settings.json", "experts")
    PERSONA = "lazycortex-core:lazy-memory.persona-aspect"

    summary = {"dispatched": 0, "skipped_not_persona": 0,
               "would_dispatch": 0, "errors": []}

    for name, entry in experts.items():
        if name == "_version" or not isinstance(entry, dict):
            continue
        aspects = entry.get("aspects") or []
        if PERSONA not in aspects:
            summary["skipped_not_persona"] += 1
            continue
        if args.dry_run:
            summary["would_dispatch"] += 1
            continue

        # Gather sources: recent logs + memory notes
        sources = []
        log_root = repo / ".logs/claude" / name
        cutoff = time.time() - args.days * 86400
        if log_root.is_dir():
            for p in sorted(log_root.iterdir()):
                if p.is_file() and p.suffix == ".md" and p.stat().st_mtime >= cutoff:
                    sources.append({"path": str(p), "description": "recent run log"})
        mem_root = repo / ".memory" / name
        if mem_root.is_dir():
            for p in sorted(mem_root.iterdir()):
                if p.is_file() and p.suffix == ".md":
                    sources.append({"path": str(p), "description": "current memory note"})

        payload = {
            "kind": "reflect",
            "role": "reflect",
            "request": (
                "Consolidate recent runs into memory per lazy-memory.persona-aspect "
                "§Obligations. Use /lazy-memory.write for any new or updated notes. "
                "Return outcome=empty if nothing is worth consolidating."
            ),
            "source": sources,
        }
        try:
            dispatch_job(repo, name, payload)
            summary["dispatched"] += 1
        except Exception as e:
            summary["errors"].append({"expert": name, "error": str(e)})

    print(json.dumps(summary))
    return 0


def _cmd_error_record(argv: list[str]) -> int:
    """Record one error event (or resolve an incident) from CLI flags.

    Other plugins call this over the published CLI to register an error the
    runtime did not capture as a job/routine failure. Best-effort: the underlying
    ``error_ledger.record`` never raises. On open, prints ``{"recorded": true, "id": "<ulid>"}``
    so the caller can correlate; ``--cause`` is required (closed-set) so a plugin can't drop a
    causeless event into the ledger.
    """
    import argparse, json
    import error_ledger
    p = argparse.ArgumentParser(prog="lazycortex-core error-record")
    p.add_argument("--incident", required=True)
    p.add_argument("--kind", default="plugin_error")
    p.add_argument("--cause")
    p.add_argument("--severity", default="error", choices=["error", "warn"])
    p.add_argument("--detail", default="")
    p.add_argument("--expert")
    p.add_argument("--job-id")
    p.add_argument("--routine")
    p.add_argument("--resolve", action="store_true")
    p.add_argument("--resolution", default="manual")
    a = p.parse_args(argv)
    repo = Path.cwd()
    # guard: --resolve closes an incident instead of opening one; cause is meaningless for the close path
    if a.resolve:
        event_id = error_ledger.new_id()
        error_ledger.resolve(repo, a.incident, resolution=a.resolution, id=event_id)
    else:
        # guard: opening an event without a cause violates the closed-set contract — refuse the call
        if not a.cause:
            print("error-record: --cause is required when opening an event", file=sys.stderr)
            return 2
        event_id = error_ledger.new_id()
        error_ledger.record(repo, {
            "id": event_id,
            "incident": a.incident, "phase": "opened", "kind": a.kind, "cause": a.cause,
            "severity": a.severity, "detail": a.detail, "actor": "plugin-cli",
            "expert": a.expert, "job_id": a.job_id, "routine": a.routine,
        })
    print(json.dumps({"recorded": True, "id": event_id}))
    return 0


def _cmd_resume(argv: list[str]) -> int:
    """Clear the daemon's halt block so the runtime resumes work.

    Reason-aware (see ``recover.resume``): ``uncommitted_changes`` requires a
    clean working tree; other reasons (``suspected_loop``, ``git_pull_diverged``,
    ``git_push_failed``, ``git_remote_unavailable``, future) clear unconditionally.
    If the underlying cause still holds, the daemon will re-halt on the next
    iteration — clearing is always safe, never destructive.

    Idempotent: if the daemon is not halted, exits 0 with ``resumed: false``.
    """
    import argparse, json
    import recover
    p = argparse.ArgumentParser(prog="lazycortex-core resume")
    p.add_argument("repo", nargs="?", default=None,
                   help="Repository root (default: $LAZY_REPO_ROOT or cwd)")
    a = p.parse_args(argv)
    repo_path = Path(a.repo) if a.repo else Path(os.environ.get("LAZY_REPO_ROOT", os.getcwd()))
    halt_before = recover.read_halt(repo_path)
    # guard: daemon is not halted — idempotent no-op
    if halt_before is None:
        print(json.dumps({"resumed": False, "halt": None, "note": "daemon not halted"}))
        return 0
    try:
        recover.resume(repo_path)
    except recover.RecoverError as e:
        print(json.dumps({"resumed": False, "halt": halt_before, "error": str(e)}), file=sys.stderr)
        return 1
    print(json.dumps({"resumed": True, "halt": halt_before}))
    return 0


def _cmd_error_list(argv: list[str]) -> int:
    """Print error-ledger incidents as JSON, optionally filtered by state / kind / since-cursor."""
    import argparse, json
    import error_ledger
    p = argparse.ArgumentParser(prog="lazycortex-core error-list")
    p.add_argument("--state", default="all", choices=["all", "open", "needs_operator", "closed"])
    p.add_argument("--kind", default=None)
    p.add_argument("--since", default=None,
                   help="ULID cursor; only incidents whose latest event id is strictly greater are returned")
    a = p.parse_args(argv)
    rows = error_ledger.incidents(Path.cwd(), state=a.state, since=a.since)
    # guard: optional kind filter
    if a.kind:
        rows = [r for r in rows if r.get("kind") == a.kind]
    print(json.dumps(rows, ensure_ascii=False))
    return 0


def main() -> int:
    if len(sys.argv) < 2:
        print(USAGE, file=sys.stderr); return 2
    sub = sys.argv[1]
    repo = Path(os.environ.get("LAZY_REPO_ROOT", os.getcwd()))
    if sub == "expert-pump-once":
        from expert_pump import pump
        result = pump(repo)
        print(f"experts={result['experts']} processed={result['processed']} cleaned={result['cleaned']}")
        return 0
    elif sub == "doctor-tick":
        import json
        from doctor_tick import doctor_tick
        result = doctor_tick(repo)
        print(json.dumps(result))
        return 0
    elif sub == "runtime":
        from runtime_daemon import run
        run(repo); return 0
    elif sub == "resume":
        return _cmd_resume(sys.argv[2:])
    elif sub == "memory-reflect-all":
        return _cmd_memory_reflect_all(sys.argv[2:])
    elif sub == "dispatch-job":
        return _cmd_dispatch_job(sys.argv[2:])
    elif sub == "collect-job":
        return _cmd_collect_job(sys.argv[2:])
    elif sub == "consume-job":
        return _cmd_consume_job(sys.argv[2:])
    elif sub == "lookup-expert":
        return _cmd_lookup_expert(sys.argv[2:])
    elif sub == "scaffold":
        from scaffold_registry import main as _scaffold_main
        return _scaffold_main(sys.argv[2:])
    elif sub == "error-record":
        return _cmd_error_record(sys.argv[2:])
    elif sub == "error-list":
        return _cmd_error_list(sys.argv[2:])
    elif sub == "settings-get":
        from settings_cli import cmd_settings_get
        return cmd_settings_get(sys.argv[2:])
    elif sub == "settings-set":
        from settings_cli import cmd_settings_set
        return cmd_settings_set(sys.argv[2:])
    else:
        print(f"unknown subcommand: {sub}\n{USAGE}", file=sys.stderr); return 2


if __name__ == "__main__":
    sys.exit(main())
