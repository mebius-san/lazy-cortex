#!/usr/bin/env zsh
# tst — Python test runner for the lazycortex-python plugin.
#
# Sources the shared venv (mypy/pylint/pytest), then the optional project-env
# bootstrap (python.env_source in .claude/lazy.settings.json), then runs pytest
# scoped to the requested module under tests/<module>/, or all tests if no arg given.
#
# Usage:
#   tst                  # run pytest across all tests/ subdirs
#   tst <module>         # run pytest on tests/<module>/ only
#   tst -q [<module>]    # -q is accepted as a no-op (per lazy-python.style.md mandate)
#   tst --help           # print this usage
#
# Runs standalone from a bare terminal — CLAUDE_PLUGIN_ROOT / CLAUDE_PLUGIN_DATA
# are optional (only an optimization for the venv helper's probe 4; probes 1-3 +
# self-derivation work without them).
set -e
set -u
set -o pipefail

# directory containing the script
script_dir="$(cd "$(dirname "$0")" && pwd)"

function print_help() {
  echo "run Python tests via pytest"
  echo "usage: tst [<module>]"
  echo
  echo "  <module>   one of the names under tests/ (e.g., 'core', 'rpg')"
  echo "             omit to run all tests"
  echo
  echo "  -q         accepted as no-op (lazy-python.style.md compat)"
  echo "  --help     this help"
  echo
}

# help shortcut
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  print_help
  exit 0
fi

# parse args: collect non-flag positional, swallow -q
mod=""
while [ -n "${1-}" ]; do
  if [ "$1" = "-q" ]; then
    shift
    continue
  fi
  if [ -z "$mod" ]; then
    mod="$1"
  else
    echo "tst: unexpected extra arg: $1" >&2
    print_help
    exit 1
  fi
  shift
done

source "$script_dir/_ensure_venv.sh"
# Optional project-env bootstrap (python.env_source) — must run after the venv is
# active and before pytest is exec'd, in this same shell so exports are inherited.
source "$script_dir/_ensure_env.sh"

# Make the re-export dedup plugin importable (it lives beside this script in bin/),
# appended so the consumer's own PYTHONPATH entries keep precedence, then load it with
# `-p _pytest_dedup`. It collapses tests collected twice via re-export shims (a test_all.py
# aggregator + per-package shims) so each test runs once; a no-op in repos without shims.
export PYTHONPATH="${PYTHONPATH:+$PYTHONPATH:}$script_dir"

if [ -z "$mod" ]; then
  exec pytest -q -p _pytest_dedup tests/
else
  exec pytest -q -p _pytest_dedup "tests/${mod}/"
fi
