{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "title": "LazyCortex Runtime",
  "uid": "lazycortex-runtime",
  "tags": [
    "lazycortex",
    "runtime",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "hidden": true
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "${DS_PROMETHEUS}"
        },
        "hide": 2
      },
      {
        "name": "period",
        "type": "custom",
        "label": "period",
        "query": "1h, 6h, 12h, 24h, 7d, 30d",
        "options": [
          {
            "selected": false,
            "text": "1h",
            "value": "1h"
          },
          {
            "selected": false,
            "text": "6h",
            "value": "6h"
          },
          {
            "selected": false,
            "text": "12h",
            "value": "12h"
          },
          {
            "selected": true,
            "text": "24h",
            "value": "24h"
          },
          {
            "selected": false,
            "text": "7d",
            "value": "7d"
          },
          {
            "selected": false,
            "text": "30d",
            "value": "30d"
          }
        ],
        "current": {
          "selected": true,
          "text": "24h",
          "value": "24h"
        }
      },
      {
        "name": "repo",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(lazycortex_runtime_routine_ticks_total, repo)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "type": "table",
      "title": "Daemons ($period)",
      "description": "One row per runtime daemon: liveness, halt state, problem jobs now, errors and tokens over the selected period.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "max by (repo) (lazycortex_runtime_daemon_halted{repo=~\"$repo\"}) or 0 * max by (repo) (lazycortex_runtime_build_info{repo=~\"$repo\"})",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (repo) (lazycortex_runtime_queue_depth{repo=~\"$repo\",state=\"failed\"}) or 0 * max by (repo) (lazycortex_runtime_build_info{repo=~\"$repo\"})",
          "legendFormat": "",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (repo) (lazycortex_runtime_queue_depth{repo=~\"$repo\",state=\"dead\"}) or 0 * max by (repo) (lazycortex_runtime_build_info{repo=~\"$repo\"})",
          "legendFormat": "",
          "refId": "D",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (repo) (increase(lazycortex_runtime_routine_errors_total{repo=~\"$repo\"}[$period])) or 0 * max by (repo) (lazycortex_runtime_build_info{repo=~\"$repo\"})",
          "legendFormat": "",
          "refId": "E",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "max by (repo) (lazycortex_runtime_dirty_tree{repo=~\"$repo\"}) or 0 * max by (repo) (lazycortex_runtime_build_info{repo=~\"$repo\"})",
          "legendFormat": "",
          "refId": "G",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "exported_repo": true
            },
            "indexByName": {
              "repo": 0,
              "Value #B": 2,
              "Value #C": 4,
              "Value #D": 5,
              "Value #E": 6,
              "Value #G": 3
            },
            "renameByName": {
              "repo": "Daemon",
              "Value #B": "Halted",
              "Value #C": "Failed jobs",
              "Value #D": "Dead jobs",
              "Value #E": "Errors",
              "Value #G": "Work"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false,
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Halted"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "OK",
                        "color": "green"
                      },
                      "1": {
                        "text": "HALTED",
                        "color": "red"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^(Failed jobs|Dead jobs|Errors)$"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 5
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Work"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "OK",
                        "color": "green"
                      },
                      "1": {
                        "text": "PAUSED \u2014 dirty tree",
                        "color": "orange"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": [],
          "countRows": false,
          "enablePagination": false
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Errors"
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Routine health ($period)",
      "description": "One row per routine \u00d7 repo: how long since the last tick, tick and error counts over the selected period.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (routine, repo) (increase(lazycortex_runtime_routine_ticks_total{repo=~\"$repo\"}[$period]))",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (routine, repo) (increase(lazycortex_runtime_routine_runs_total{repo=~\"$repo\"}[$period])) or 0 * sum by (routine, repo) (increase(lazycortex_runtime_routine_ticks_total{repo=~\"$repo\"}[$period]))",
          "legendFormat": "",
          "refId": "E",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (routine, repo) (increase(lazycortex_runtime_routine_errors_total{repo=~\"$repo\"}[$period])) or 0 * sum by (routine, repo) (increase(lazycortex_runtime_routine_ticks_total{repo=~\"$repo\"}[$period]))",
          "legendFormat": "",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (routine, repo) (increase(lazycortex_runtime_routine_tick_duration_seconds_sum{repo=~\"$repo\"}[$period]))",
          "legendFormat": "",
          "refId": "D",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "exported_repo": true
            },
            "indexByName": {
              "routine": 0,
              "repo": 1,
              "Value #B": 3,
              "Value #E": 4,
              "Value #C": 5,
              "Value #D": 6
            },
            "renameByName": {
              "routine": "Routine",
              "repo": "Repo",
              "Value #B": "Ticks",
              "Value #C": "Errors",
              "Value #D": "Busy time",
              "Value #E": "Runs"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false,
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Ticks"
            },
            "properties": [
              {
                "id": "min",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Busy time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "min",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Errors"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "text",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 5
                    }
                  ]
                }
              },
              {
                "id": "min",
                "value": 0
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": [],
          "countRows": false,
          "enablePagination": false
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Ticks"
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Errors by routine \u00d7 reason ($period)",
      "description": "Empty table = no errors in the selected period.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (routine, repo, reason) (increase(lazycortex_runtime_routine_errors_total{repo=~\"$repo\"}[$period])) > 0",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "exported_repo": true
            },
            "indexByName": {
              "routine": 0,
              "repo": 1,
              "reason": 2,
              "Value": 3
            },
            "renameByName": {
              "routine": "Routine",
              "repo": "Repo",
              "reason": "Reason",
              "Value": "Errors"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false,
            "inspect": false
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": [],
          "countRows": false,
          "enablePagination": false
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Errors"
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Halt events ($period)",
      "description": "Empty table = no halts in the selected period.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (repo, reason, triggered_by) (increase(lazycortex_runtime_daemon_halts_total{repo=~\"$repo\"}[$period])) > 0",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "exported_repo": true
            },
            "indexByName": {
              "repo": 0,
              "reason": 1,
              "triggered_by": 2,
              "Value": 3
            },
            "renameByName": {
              "repo": "Repo",
              "reason": "Reason",
              "triggered_by": "Triggered by",
              "Value": "Halts"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false,
            "inspect": false
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": [],
          "countRows": false,
          "enablePagination": false
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Halts"
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Queue by expert \u00d7 state (now)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (expert, repo, state) (lazycortex_runtime_queue_depth{repo=~\"$repo\",state!=\"done\"}) > 0",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "exported_repo": true
            },
            "indexByName": {
              "expert": 0,
              "repo": 1,
              "state": 2,
              "Value": 3
            },
            "renameByName": {
              "expert": "Expert",
              "repo": "Repo",
              "state": "State",
              "Value": "Jobs"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false,
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "failed": {
                        "color": "orange",
                        "index": 0
                      },
                      "dead": {
                        "color": "red",
                        "index": 1
                      },
                      "active": {
                        "color": "green",
                        "index": 2
                      },
                      "queued": {
                        "color": "blue",
                        "index": 3
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": [],
          "countRows": false,
          "enablePagination": false
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Jobs"
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Open jobs (queued / active, $period)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "timeFrom": "$period",
      "targets": [
        {
          "expr": "sum by (expert, repo, state) (lazycortex_runtime_queue_depth{repo=~\"$repo\",state=~\"queued|active\"})",
          "legendFormat": "{{expert}} / {{repo}} \u00b7 {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Problem jobs (failed / dead, $period)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "timeFrom": "$period",
      "targets": [
        {
          "expr": "sum by (expert, repo, state) (lazycortex_runtime_queue_depth{repo=~\"$repo\",state=~\"failed|dead\"})",
          "legendFormat": "{{expert}} / {{repo}} \u00b7 {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*dead.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*failed.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "table",
      "title": "Tokens by routine \u00d7 model \u00d7 expert ($period)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "label_replace(sum by (routine, repo, model, expert) (increase(lazycortex_runtime_tokens_total{repo=~\"$repo\",kind=\"input\"}[$period])), \"model\", \"$1\", \"model\", \"claude-(.+)\")",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "label_replace(sum by (routine, repo, model, expert) (increase(lazycortex_runtime_tokens_total{repo=~\"$repo\",kind=\"output\"}[$period])), \"model\", \"$1\", \"model\", \"claude-(.+)\")",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "label_replace(sum by (routine, repo, model, expert) (increase(lazycortex_runtime_tokens_total{repo=~\"$repo\",kind=\"cache_read\"}[$period])), \"model\", \"$1\", \"model\", \"claude-(.+)\")",
          "legendFormat": "",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "label_replace(sum by (routine, repo, model, expert) (increase(lazycortex_runtime_tokens_total{repo=~\"$repo\",kind=\"cache_write\"}[$period])), \"model\", \"$1\", \"model\", \"claude-(.+)\")",
