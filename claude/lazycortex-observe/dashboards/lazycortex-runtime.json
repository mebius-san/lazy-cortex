{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "panel",      "id": "timeseries",     "name": "Time series",  "version": ""},
    {"type": "panel",      "id": "stat",           "name": "Stat",         "version": ""},
    {"type": "panel",      "id": "table",          "name": "Table",        "version": ""},
    {"type": "datasource", "id": "prometheus",     "name": "Prometheus",   "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "title": "LazyCortex Runtime",
  "uid": "lazycortex-runtime",
  "tags": ["lazycortex", "runtime", "observability"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "${DS_PROMETHEUS}"},
        "hide": 0
      },
      {
        "name": "routine",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(lazycortex_runtime_routine_ticks_total, routine)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      },
      {
        "name": "repo",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(lazycortex_runtime_routine_ticks_total, repo)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Tick rate (per minute, by routine × repo)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "60 * sum by (routine, repo) (rate(lazycortex_runtime_routine_ticks_total{routine=~\"$routine\",repo=~\"$repo\"}[5m]))",
          "legendFormat": "{{routine}} / {{repo}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Error rate (by routine × reason)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "60 * sum by (routine, reason) (rate(lazycortex_runtime_routine_errors_total{routine=~\"$routine\",repo=~\"$repo\"}[5m]))",
          "legendFormat": "{{routine}} · {{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Tick duration p50 / p95 / p99",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, routine) (rate(lazycortex_runtime_routine_tick_duration_seconds_bucket{routine=~\"$routine\",repo=~\"$repo\"}[5m])))",
          "legendFormat": "p50 {{routine}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, routine) (rate(lazycortex_runtime_routine_tick_duration_seconds_bucket{routine=~\"$routine\",repo=~\"$repo\"}[5m])))",
          "legendFormat": "p95 {{routine}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, routine) (rate(lazycortex_runtime_routine_tick_duration_seconds_bucket{routine=~\"$routine\",repo=~\"$repo\"}[5m])))",
          "legendFormat": "p99 {{routine}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Queue depth (by expert × state)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (expert, repo, state) (lazycortex_runtime_queue_depth{repo=~\"$repo\"})",
          "legendFormat": "{{expert}} / {{repo}} · {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"displayMode": "table"}}
    },
    {
      "type": "timeseries",
      "title": "Tokens / hour (by routine × kind)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "3600 * sum by (routine, repo, kind) (rate(lazycortex_runtime_tokens_total{routine=~\"$routine\",repo=~\"$repo\"}[1h]))",
          "legendFormat": "{{routine}} / {{repo}} · {{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "type": "table",
      "title": "Last-tick staleness (seconds since last tick)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "time() - lazycortex_runtime_routine_last_tick_timestamp{routine=~\"$routine\",repo=~\"$repo\"}",
          "legendFormat": "{{routine}} / {{repo}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 600},
              {"color": "red",    "value": 3600}
            ]
          },
          "custom": {"displayMode": "color-background"}
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Daemon halt status",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 24},
      "targets": [
        {
          "expr": "max by (repo, reason, triggered_by) (lazycortex_runtime_daemon_halted{repo=~\"$repo\"})",
          "legendFormat": "{{repo}} ({{triggered_by}}: {{reason}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red",   "value": 1}
            ]
          },
          "mappings": [
            {"type": "value", "options": {"0": {"text": "healthy"}, "1": {"text": "HALTED"}}}
          ]
        }
      },
      "options": {"colorMode": "background", "graphMode": "none"}
    },
    {
      "type": "table",
      "title": "Halt event count (last 24h)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 24},
      "targets": [
        {
          "expr": "sum by (repo, triggered_by) (increase(lazycortex_runtime_daemon_halts_total{repo=~\"$repo\"}[24h]))",
          "legendFormat": "{{repo}} / {{triggered_by}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ]
}
