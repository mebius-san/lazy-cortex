{
  "description": "LazyCortex core hooks — settings protection, pre-commit security scanning, and staging-window mutex",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-guard.settings.py\"",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-guard.check-public.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-core.git-guard.py\"",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "mcp__git__git_commit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-guard.check-public.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-core.git-guard.py\"",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "mcp__git__git_add",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-core.git-guard.py\"",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "mcp__git__git_reset",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-core.git-guard.py\"",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-core.model-router.py\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-core.git-guard.py\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-log.commit-recorder.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__git__git_commit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-core.git-guard.py\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-log.commit-recorder.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__git__git_reset",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lazy-core.git-guard.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
